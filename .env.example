# =COLLE_TA_VALEUR_ICI
# CDM 2026 LIVE BY REDHA — BACKEND V5
# .env AVEC CLES — BACKEND UNIQUEMENT
#
# IMPORTANT SECURITE :
# - Ce fichier est pour Codex / backend seulement.
# - Ne jamais mettre ce fichier dans l'APK Android.
# - Ne jamais publier ce fichier sur GitHub.
# - Ne jamais afficher les clés dans le Diagnostic Android.
# =COLLE_TA_VALEUR_ICI

NODE_ENV=production
PORT=3000

# Remplacer après déploiement Railway / Render / VPS
PUBLIC_BACKEND_URL=https://TON-BACKEND-PUBLIC-ICI
CORS_ORIGIN=*

# ---- FAPI / TheStatsAPI : source principale score/live/events/stats/lineups ----
FAPI_API_KEY=COLLE_TA_VALEUR_ICI
THESTATSAPI_KEY=COLLE_TA_VALEUR_ICI
THESTATSAPI_BASE_URL=https://api.thestatsapi.com/api
WORLD_CUP_COMPETITION_ID=COLLE_TA_VALEUR_ICI

# ---- SportDB / Flashscore : validation / secours ----
SPORTDB_API_KEY=COLLE_TA_VALEUR_ICI
SPORTDB_BASE_URL=https://api.sportdb.io

# ---- Source live optionnelle (backend Render uniquement) ----
# Laisser vide tant qu'un fournisseur autorise n'est pas configure.
LIVE_SCORE_PROVIDER=
LIVE_SCORE_API_KEY=

# ---- Flashscore RapidAPI : secours optionnel backend uniquement ----
FLASHSCORE_RAPIDAPI_KEY=COLLE_TA_VALEUR_ICI
FLASHSCORE_RAPIDAPI_HOST=COLLE_TA_VALEUR_ICI
FLASHSCORE_RAPIDAPI_BASE_URL=https://flashscore4.p.rapidapi.com

# ---- Gemini AI : agents internes caches ----
GEMINI_API_KEY=COLLE_TA_VALEUR_ICI
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLE_AGENTS=true

ENABLE_SCORE_AGENT=true
ENABLE_CARD_AGENT=true
ENABLE_INJURY_AGENT=true
ENABLE_INTERVIEW_AGENT=true
ENABLE_TRAINING_AGENT=true
ENABLE_MEDIA_AGENT=true
ENABLE_TRUST_AGENT=true
ENABLE_NOTIFICATION_AGENT=true
ENABLE_COMMENTARY_AGENT=true
ENABLE_ANALYST_AGENT=true
ENABLE_PREDICTION_AGENT=true
ENABLE_JOURNALIST_AGENT=true

# ---- YouTube / RSS / medias officiels ----
YOUTUBE_API_KEY=COLLE_TA_VALEUR_ICI
ENABLE_YOUTUBE=true
ENABLE_RSS=true
FIFA_RSS_URL=https://www.fifa.com/fifaplus/en/rss
FIFA_YOUTUBE_CHANNEL_ID=COLLE_TA_VALEUR_ICI
FAF_OFFICIAL_URL=https://www.faf.dz
FAF_YOUTUBE_CHANNEL_ID=COLLE_TA_VALEUR_ICI

# ---- Firebase FCM ----
# Methode recommandee : coller le JSON service account Firebase en base64 sur Railway/Render.
FIREBASE_SERVICE_ACCOUNT_BASE64=COLLE_TA_VALEUR_ICI
FIREBASE_SERVICE_ACCOUNT_PATH=COLLE_TA_VALEUR_ICI
FCM_ENABLED=true

# ---- Polling / cache ----
LIVE_POLL_INTERVAL_SECONDS=COLLE_TA_VALEUR_ICI
TODAY_POLL_INTERVAL_SECONDS=COLLE_TA_VALEUR_ICI
UPCOMING_CACHE_SECONDS=COLLE_TA_VALEUR_ICI
TEAM_CACHE_SECONDS=COLLE_TA_VALEUR_ICI
MEDIA_CACHE_SECONDS=COLLE_TA_VALEUR_ICI
NOTIFICATION_DEDUP_TTL_SECONDS=COLLE_TA_VALEUR_ICI

# ---- Logs / securite ----
LOG_LEVEL=info
HIDE_SECRETS_IN_LOGS=true
